{
  "entities": {
    "Topic": {
      "title": "Topic",
      "description": "A high-level subject or report being analyzed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "creatorId", "category", "createdAt"]
    },
    "AtomicClaim": {
      "title": "Atomic Claim",
      "description": "A single verifiable statement extracted from a topic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "statement": { "type": "string" },
        "type": { "type": "string", "enum": ["factual", "opinion", "speculation", "prediction"] },
        "status": { "type": "string", "enum": ["verified", "disputed", "unverified"] },
        "confidence": { "type": "number" },
        "creatorId": { "type": "string" },
        "sourceIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "interactionCount": { "type": "number" }
      },
      "required": ["id", "topicId", "statement", "type", "status", "confidence", "creatorId", "sourceIds", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "A structured AI-generated report view of a topic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["balanced", "comparison", "verification", "impact", "challenge"] },
        "slides": { "type": "array" },
        "claimIds": { "type": "array", "items": { "type": "string" } },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "topicId", "title", "type", "slides", "claimIds", "creatorId", "createdAt"]
    },
    "Source": {
      "title": "Source",
      "description": "A grounded reference link/citation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "citation": { "type": "string" },
        "addedById": { "type": "string" }
      },
      "required": ["id", "topicId", "title", "url", "citation", "addedById"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A user-contributed forensic interrogation event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "claimId": { "type": "string" },
        "topicId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["confirm", "question", "dispute", "refine"] },
        "content": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "claimId", "topicId", "userId", "type", "createdAt"]
    },
    "NarrativeDeck": {
      "title": "Narrative Deck",
      "description": "A user-created sequence of claims forming an interpretation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "thesis": { "type": "string" },
        "intent": { "type": "string", "enum": ["explain", "case", "challenge", "explore"] },
        "slides": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "creatorName": { "type": "string" },
        "creatorPhoto": { "type": "string" },
        "interactionCount": { "type": "number" }
      },
      "required": ["id", "topicId", "creatorId", "title", "thesis", "intent", "slides", "createdAt"]
    }
  },
  "firestore": {
    "/topics/{topicId}": {
      "schema": "Topic",
      "description": "Collection of analysis topics."
    },
    "/topics/{topicId}/claims/{claimId}": {
      "schema": "AtomicClaim",
      "description": "Claims associated with a topic."
    },
    "/topics/{topicId}/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "AI analysis reports for a topic."
    },
    "/topics/{topicId}/sources/{sourceId}": {
      "schema": "Source",
      "description": "Grounding sources for a topic."
    },
    "/topics/{topicId}/narratives/{narrativeId}": {
      "schema": "NarrativeDeck",
      "description": "User-generated narratives for a topic."
    },
    "/topics/{topicId}/claims/{claimId}/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "User interactions (verifications, disputes) for a claim."
    }
  }
}
