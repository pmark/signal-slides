{
  "entities": {
    "Source": {
      "title": "Source",
      "description": "Information input (URL or text) being analyzed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "content": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "creatorId", "createdAt"]
    },
    "Claim": {
      "title": "Claim",
      "description": "An atomic assertion extracted from a source.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sourceId": { "type": "string" },
        "statement": { "type": "string" },
        "classification": { "type": "string", "enum": ["verifiable", "opinion", "speculation", "prediction"] },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "relatedClaimIds": { "type": "array", "items": { "type": "string" } },
        "opposingClaimIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "sourceId", "statement", "classification", "creatorId", "createdAt"]
    },
    "Deck": {
      "title": "Deck",
      "description": "A shareable sequence of claims forming a narrative.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sourceId": { "type": "string" },
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "intent": { "type": "string", "enum": ["explain", "case", "challenge", "compare"] },
        "slides": { "type": "array" },
        "parentDeckId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "creatorName": { "type": "string" },
        "creatorPhoto": { "type": "string" }
      },
      "required": ["id", "sourceId", "creatorId", "title", "intent", "slides", "createdAt"]
    }
  },
  "firestore": {
    "/sources/{sourceId}": {
      "schema": "Source",
      "description": "Root input content."
    },
    "/sources/{sourceId}/claims/{claimId}": {
      "schema": "Claim",
      "description": "Claims extracted from the source."
    },
    "/sources/{sourceId}/decks/{deckId}": {
      "schema": "Deck",
      "description": "Narrative decks built from the claims."
    }
  }
}
