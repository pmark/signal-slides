rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.creatorId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "wayoutwest@gmail.com" && request.auth.token.email_verified == true
      );
    }

    // --- Entity Validators ---

    function isValidSource(data) {
      return data.keys().hasAll(['id', 'title', 'creatorId', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 300
        && data.creatorId == request.auth.uid
        && data.createdAt is timestamp
        && (!('url' in data) || (data.url == null || (data.url is string && data.url.size() <= 2000)))
        && (!('content' in data) || (data.content == null || (data.content is string && data.content.size() <= 200000)));
    }

    function isValidClaim(data) {
      return data.keys().hasAll(['id', 'sourceId', 'statement', 'classification', 'creatorId', 'createdAt'])
        && data.size() >= 6 && data.size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.sourceId is string && data.sourceId.size() <= 128
        && data.statement is string && data.statement.size() <= 2000
        && data.classification in ['verifiable', 'opinion', 'speculation', 'prediction']
        && data.creatorId == request.auth.uid
        && data.createdAt is timestamp
        && (!('relatedClaimIds' in data) || (data.relatedClaimIds is list && data.relatedClaimIds.size() <= 50))
        && (!('opposingClaimIds' in data) || (data.opposingClaimIds is list && data.opposingClaimIds.size() <= 50));
    }

    function isValidDeck(data) {
      return data.keys().hasAll(['id', 'sourceId', 'creatorId', 'title', 'intent', 'slides', 'createdAt'])
        && data.size() >= 7 && data.size() <= 11
        && data.id is string && data.id.size() <= 128
        && data.sourceId is string && data.sourceId.size() <= 128
        && data.creatorId == request.auth.uid
        && data.title is string && data.title.size() <= 300
        && data.intent in ['explain', 'case', 'challenge', 'compare']
        && data.slides is list && data.slides.size() <= 100
        && data.createdAt is timestamp
        && (!('status' in data) || data.status in ['draft', 'published'])
        && (!('parentDeckId' in data) || (data.parentDeckId is string && data.parentDeckId.size() <= 128))
        && (!('creatorName' in data) || (data.creatorName is string && data.creatorName.size() <= 200))
        && (!('creatorPhoto' in data) || (data.creatorPhoto is string && data.creatorPhoto.size() <= 2000));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt', 'lastLogin'])
        && data.uid == request.auth.uid
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 200))
        && (!('email' in data) || (data.email is string && data.email.size() <= 320))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2000));
    }

    // --- Collection Rules ---

    match /extraction_cache/{inputHash} {
      // Global read to allow any user to benefit from previous extractions
      allow get: if true;
      // Allow creation of cache entries by any verified user
      allow create: if isEmailVerified() && isValidId(inputHash) 
        && incoming().inputHash == inputHash
        && incoming().createdAt == request.time;
      // No updates or deletes allowed for regular users to maintain cache integrity
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && userId == request.auth.uid 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().lastLogin == request.time;
      allow update: if isSignedIn() && userId == request.auth.uid 
        && incoming().createdAt == existing().createdAt
        && incoming().lastLogin == request.time
        && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin']) ||
          incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'displayName', 'photoURL', 'email'])
        );
    }

    match /sources/{sourceId} {
      allow get: if true;
      allow list: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(sourceId) && isValidSource(incoming());
      
      allow update: if false; 
      allow delete: if isAdmin() || isOwner(existing());

      match /claims/{claimId} {
        allow get: if true;
        allow list: if true;
        allow create: if isEmailVerified() && isValidId(claimId) && isValidClaim(incoming())
          && incoming().sourceId == sourceId;
        
        allow update: if isEmailVerified() && (
          isAdmin() || 
          (isOwner(existing()) && isValidClaim(incoming()) && incoming().sourceId == sourceId)
        );
        allow delete: if isAdmin() || isOwner(existing());
      }

      match /decks/{deckId} {
        allow get: if true;
        allow list: if true;
        allow create: if isEmailVerified() && isValidId(deckId) && isValidDeck(incoming())
          && incoming().sourceId == sourceId;
        
        allow update: if isEmailVerified() && (
          isAdmin() || 
          (isOwner(existing()) && (
            // Basic update allows changing everything except immutable relational IDs
            (isValidDeck(incoming()) && incoming().sourceId == sourceId && incoming().creatorId == existing().creatorId)
          ))
        );
        allow delete: if isAdmin() || isOwner(existing());
      }
    }
  }
}
