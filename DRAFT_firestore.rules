rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == "wayoutwest@gmail.com" && request.auth.token.email_verified == true);
    }

    // --- Entity Validators ---

    function isValidSource(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && (!('url' in data) || (data.url is string && data.url.size() <= 2000))
        && (!('content' in data) || (data.content is string && data.content.size() <= 50000))
        && data.creatorId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidClaim(data) {
      return data.id is string && data.id.size() <= 128
        && data.sourceId is string && data.sourceId.size() <= 128
        && data.statement is string && data.statement.size() <= 1000
        && data.classification in ['verifiable', 'opinion', 'speculation', 'prediction']
        && data.creatorId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidDeck(data) {
      return data.id is string && data.id.size() <= 128
        && data.sourceId is string && data.sourceId.size() <= 128
        && data.creatorId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.intent in ['explain', 'case', 'challenge', 'compare']
        && data.slides is list && data.slides.size() <= 50
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /sources/{sourceId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidId(sourceId) && isValidSource(incoming());
      
      allow update: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin())
        && isValidSource(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title']);

      match /claims/{claimId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(claimId) && isValidClaim(incoming())
          && incoming().sourceId == sourceId;
        
        allow update: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin())
          && incoming().diff(existing()).affectedKeys().hasOnly(['statement', 'classification', 'relatedClaimIds', 'opposingClaimIds'])
          && incoming().sourceId == existing().sourceId;
      }

      match /decks/{deckId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(deckId) && isValidDeck(incoming())
          && incoming().sourceId == sourceId;
        
        allow update: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin())
          && isValidDeck(incoming())
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['title', 'slides', 'intent']) ||
            (incoming().diff(existing()).affectedKeys().hasOnly(['interactionCount']) && incoming().interactionCount == existing().get('interactionCount', 0) + 1)
          )
          && incoming().sourceId == existing().sourceId;
        
        allow delete: if isSignedIn() && (isOwner(existing().creatorId) || isAdmin());
      }
    }
  }
}
