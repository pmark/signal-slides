rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Validators ---

    function isValidTopic(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1000
        && data.creatorId == request.auth.uid
        && data.category is string && data.category.size() <= 50
        && data.createdAt == request.time;
    }

    function isValidClaim(data) {
      return data.id is string && data.id.size() <= 128
        && data.topicId is string && data.topicId.size() <= 128
        && data.statement is string && data.statement.size() <= 500
        && data.type in ['factual', 'opinion', 'speculation', 'prediction']
        && data.status in ['verified', 'disputed', 'unverified']
        && data.confidence is number && data.confidence >= 0 && data.confidence <= 1
        && data.creatorId == request.auth.uid
        && data.sourceIds is list && data.sourceIds.size() <= 20
        && data.createdAt == request.time;
    }

    function isValidInteraction(data) {
      return data.id is string && data.id.size() <= 128
        && data.claimId is string && data.claimId.size() <= 128
        && data.topicId is string && data.topicId.size() <= 128
        && data.userId == request.auth.uid
        && data.type in ['confirm', 'question', 'dispute', 'refine']
        && (!('content' in data) || (data.content is string && data.content.size() <= 2000))
        && data.createdAt == request.time;
    }

    function isValidNarrative(data) {
      return data.id is string && data.id.size() <= 128
        && data.topicId is string && data.topicId.size() <= 128
        && data.creatorId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.thesis is string && data.thesis.size() <= 1000
        && data.intent in ['explain', 'case', 'challenge', 'explore']
        && data.slides is list && data.slides.size() <= 50
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    // Topics: Publicly readable, created by users
    match /topics/{topicId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidId(topicId) && isValidTopic(incoming());
      
      // Action: Edit metadata
      allow update: if isSignedIn() && (
        // isOwner(existing().creatorId) || isAdmin()
        (request.auth.uid == existing().creatorId || (request.auth.token.email == "wayoutwest@gmail.com" && request.auth.token.email_verified == true)) &&
        isValidTopic(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'tags'])
      );

      // Claims: Individual forensic units
      match /claims/{claimId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(claimId) && isValidClaim(incoming())
          && incoming().topicId == topicId;
        
        allow update: if isSignedIn() && (
          // Action: Interaction Sync (Anyone can increment)
          (incoming().diff(existing()).affectedKeys().hasOnly(['interactionCount']) && incoming().interactionCount == existing().get('interactionCount', 0) + 1) ||
          
          // Action: Status Override (Owner or System)
          ((request.auth.uid == existing().creatorId || (request.auth.token.email == "wayoutwest@gmail.com" && request.auth.token.email_verified == true)) &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'confidence', 'type']) &&
           existing().status != 'verified') // Locked if already verified
        ) && incoming().topicId == existing().topicId && incoming().creatorId == existing().creatorId;

        // Interactions: Immutable protocol events
        match /interactions/{interactionId} {
          allow get: if true;
          allow list: if true;
          allow create: if isSignedIn() && isValidId(interactionId) && isValidInteraction(incoming())
            && incoming().claimId == claimId 
            && incoming().topicId == topicId;
          
          allow update, delete: if false; // Immutable signal history
        }
      }

      // Analyses: AI-Vetted Views
      match /analyses/{analysisId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(analysisId) 
          && incoming().creatorId == request.auth.uid
          && incoming().topicId == topicId;
      }

      // Sources: Grounding references
      match /sources/{sourceId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(sourceId) 
          && incoming().topicId == topicId
          && incoming().addedById == request.auth.uid;
      }

      // Narratives: Personal interpretations
      match /narratives/{narrativeId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidId(narrativeId) && isValidNarrative(incoming())
          && incoming().topicId == topicId;
        
        allow update: if isSignedIn() && request.auth.uid == existing().creatorId
          && isValidNarrative(incoming())
          && (
            // Action: Remix/Edit
            incoming().diff(existing()).affectedKeys().hasOnly(['title', 'thesis', 'slides', 'intent']) ||
            // Action: Interaction Increment
            (incoming().diff(existing()).affectedKeys().hasOnly(['interactionCount']) && incoming().interactionCount == existing().get('interactionCount', 0) + 1)
          );
        
        allow delete: if isSignedIn() && request.auth.uid == existing().creatorId;
      }
    }
  }
}
